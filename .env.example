# ============================================
# VARIÁVEIS DE AMBIENTE — Esquerda ou Direita?
# ============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env no repositório!
# ============================================

# Chave secreta do Flask (gerada automaticamente se vazia)
FLASK_SECRET_KEY=

# Porta do servidor (padrão: 5000)
PORT=5000

# Modo debug do Flask (0 = produção, 1 = desenvolvimento)
FLASK_DEBUG=0

# Token de acesso à API do Twitter/X v2
# Obtenha em: https://developer.twitter.com/
# Plano Free — não precisa de cartão de crédito
TWITTER_BEARER_TOKEN=
